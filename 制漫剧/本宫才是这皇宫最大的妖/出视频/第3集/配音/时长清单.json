    "角色": "沈念旁白",
    "情绪": "serious",
    "钩子": "",
    "文本": "收租。，我想起白日里小禾说过，东院的张才人，已经三月没露过面。",
    "时长": 6.898,
    "start": 99.562,
    "end": 106.459,
    "gap_after": 0.4,
    "line_wav": "line_13.wav"
  },
  {
