    "角色": "沈念旁白",
    "情绪": "neutral",
    "钩子": "climax",
    "文本": "原来不是没露面。，是被当成了租子。",
    "时长": 3.311,
    "start": 106.859,
    "end": 110.17,
    "gap_after": 0.7,
