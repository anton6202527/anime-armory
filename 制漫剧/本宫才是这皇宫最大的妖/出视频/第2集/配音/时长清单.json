    "gap_after": 0.7,
    "line_wav": "line_08.wav"
  },
  {
    "idx": 9,
    "镜头": "镜头10",
    "角色": "沈念旁白",
    "情绪": "serious",
    "钩子": "",
    "文本": "她尖叫一声，身子肉眼可见地干瘪下去，化成一团翻滚的黑烟，顺着我的指缝、掌纹，一寸寸，被吸了进来。",
    "时长": 11.381,
    "start": 40.669,
    "end": 52.049,
    "gap_after": 0.4,
    "line_wav": "line_09.wav"
  },
  {
    "idx": 10,
    "镜头": "镜头11",
    "角色": "沈念旁白",
    "情绪": "neutral",
    "钩子": "",
    "文本": "没有血。只一摊冒泡的恶臭污水，和一件空荡荡瘫在地上的深蓝宫装。",
    "时长": 6.749,
    "start": 52.449,
    "end": 59.199,
    "gap_after": 0.4,
    "line_wav": "line_10.wav"
  },
  {
    "idx": 11,
    "镜头": "镜头12",
    "角色": "系统机械音",
    "情绪": "neutral",
    "钩子": "climax",
    "文本": "噬妖夺能。，已得：伪人皮·潜行。",
    "时长": 1.818,
    "start": 59.599,
    "end": 61.417,
    "gap_after": 0.7,
    "line_wav": "line_11.wav"
  },
  {
    "idx": 12,
    "镜头": "镜头13",
    "角色": "沈念旁白",
    "情绪": "neutral",
    "钩子": "hook",
    "文本": "我懂了。不是什么打怪升级的虚头巴脑。是吃。，吃一只妖，夺它一身本事——吃一个，强一分，得一术。",
    "时长": 8.458,
    "start": 62.117,
    "end": 70.575,
    "gap_after": 0.6,
    "line_wav": "line_12.wav"
  },
  {
    "idx": 13,
    "镜头": "镜头14",
    "角色": "沈念旁白",
    "情绪": "sad",
    "钩子": "",
    "文本": "可代价，立刻找上门。热流骤然退潮，四肢百骸像被抽空，眼前发黑。",
    "时长": 6.786,
    "start": 71.175,
    "end": 77.961,
    "gap_after": 0.4,
    "line_wav": "line_13.wav"
  },
  {
    "idx": 14,
    "镜头": "镜头15",
    "角色": "沈念旁白",
    "情绪": "serious",
    "钩子": "",
    "文本": "我扶住木榻，才没栽倒。额上全是冷汗。，力，不是白来的。一次，只够吃一个。",
    "时长": 7.875,
    "start": 78.361,
    "end": 86.237,
    "gap_after": 0.4,
    "line_wav": "line_14.wav"
  },
  {
    "idx": 15,
    "镜头": "镜头16",
    "角色": "沈念旁白",
    "情绪": "neutral",
    "钩子": "",
    "文本": "金芒在眼底一点点收回，凤眼变回寻常的黑。我低头，看着地上那摊还在冒泡的污水。",
    "时长": 8.689,
    "start": 86.637,
    "end": 95.326,
    "gap_after": 0.4,
    "line_wav": "line_15.wav"
  },
