    "角色": "系统机械音",
    "情绪": "neutral",
    "钩子": "",
    "文本": "检测到妖躯。，是否……炼化？",
    "时长": 1.574,
    "start": 37.687,
    "end": 39.261,
    "gap_after": 0.4,
    "line_wav": "line_07.wav"
  },
  {
