  },
  {
    "idx": 1,
    "镜头": "镜头2",
    "角色": "柳娘子",
    "情绪": "fearful",
    "钩子": "",
    "文本": "这眼睛……你不该有这样的眼睛！来人——救——",
    "时长": 3.76,
    "start": 5.329,
    "end": 9.089,
    "gap_after": 0.4,
    "line_wav": "line_01.wav"
  },
  {
    "idx": 2,
    "镜头": "镜头3",
    "角色": "沈念旁白",
    "情绪": "neutral",
    "钩子": "",
    "文本": "她比谁都清楚。一个该被毒酒灌死的废妃，不该睁开这样一双眼。",
    "时长": 6.342,
    "start": 9.489,
    "end": 15.831,
    "gap_after": 0.4,
    "line_wav": "line_02.wav"
  },
  {
    "idx": 3,
    "镜头": "镜头4",
    "角色": "沈念旁白",
    "情绪": "fearful",
    "钩子": "",
    "文本": "我才迈出半步，人已经到了她身后。快得连我自己都怔住——这不是我的身手，是那股暗金热流，推着我动。",
    "时长": 9.004,
    "start": 16.231,
    "end": 25.235,
    "gap_after": 0.4,
    "line_wav": "line_03.wav"
  },
  {
    "idx": 4,
    "镜头": "镜头5",
    "角色": "沈念旁白",
    "情绪": "serious",
    "钩子": "",
    "文本": "一掌按上她的背。触感不对。不是血肉，是一层鞣过的冷皮，布满细鳞。",
    "时长": 6.958,
    "start": 25.635,
    "end": 32.593,
    "gap_after": 0.4,
    "line_wav": "line_04.wav"
  },
  {
    "idx": 5,
    "镜头": "镜头6",
    "角色": "沈念",
    "情绪": "neutral",
    "钩子": "hook",
    "文本": "果然。，你不是人。",
    "时长": 1.601,
    "start": 32.993,
    "end": 34.594,
    "gap_after": 0.6,
    "line_wav": "line_05.wav"
  },
  {
    "idx": 6,
    "镜头": "镜头7",
    "角色": "柳娘子",
    "情绪": "neutral",
    "钩子": "",
    "文本": "小贱人！坏我大事——",
    "时长": 2.092,
    "start": 35.194,
    "end": 37.287,
    "gap_after": 0.4,
    "line_wav": "line_06.wav"
  },
  {
