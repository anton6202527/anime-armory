    "start": 8.072,
    "end": 11.039,
    "gap_after": 0.4,
    "line_wav": "line_02.wav",
    "占位": true
  },
  {
    "idx": 3,
    "镜头": "镜头4",
    "角色": "沈念旁白",
    "情绪": "serious",
    "钩子": "",
    "文本": "我没接话。我在看。三只妖成品字站开，背后是老槐，退路只在我身侧那道矮墙。",
    "时长": 6.116,
    "start": 11.439,
    "end": 17.556,
    "gap_after": 0.4,
    "line_wav": "line_03.wav",
    "占位": true
  },
  {
