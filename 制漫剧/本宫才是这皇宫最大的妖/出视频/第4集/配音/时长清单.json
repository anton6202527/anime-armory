    "镜头": "镜头5",
    "角色": "沈念旁白",
    "情绪": "neutral",
    "钩子": "hook",
    "文本": "能打，但不能拖。我身上只有潜行，蛮力借不出来。硬拼三只小妖，撑不过十息。",
    "时长": 6.055,
    "start": 17.956,
    "end": 24.01,
    "gap_after": 0.6,
    "line_wav": "line_04.wav",
    "占位": true
  },
  {
