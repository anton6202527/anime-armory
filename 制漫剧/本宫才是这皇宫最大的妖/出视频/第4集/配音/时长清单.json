    "角色": "沈念旁白",
    "情绪": "serious",
    "钩子": "",
    "文本": "覆鳞撞上来的刹那，我没有躲。我侧身让过倒刺，反手按上它的脊背。",
    "时长": 5.269,
    "start": 86.694,
    "end": 91.963,
    "gap_after": 0.4,
    "line_wav": "line_19.wav",
    "占位": true
  },
