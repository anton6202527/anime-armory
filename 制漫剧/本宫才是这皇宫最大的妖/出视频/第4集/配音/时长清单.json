    "镜头": "镜头9",
    "角色": "沈念旁白",
    "情绪": "neutral",
    "钩子": "",
    "文本": "我绕到它颈后，五指扣住咽喉，借它自己的冲势，往老槐树干上一带。",
    "时长": 5.269,
    "start": 40.64,
    "end": 45.909,
    "gap_after": 0.4,
    "line_wav": "line_08.wav",
    "占位": true
  },
